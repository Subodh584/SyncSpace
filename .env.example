# ──────────────────────────────────────────────────────────────
# SyncSpace environment variables
# Copy this file to `.env.local` and fill in real values.
# ──────────────────────────────────────────────────────────────

# Turso (LibSQL) database
# For local dev you can use a local file: file:./local.db
# For production create a DB at https://turso.tech and paste its URL + token.
TURSO_DATABASE_URL="file:./local.db"
TURSO_AUTH_TOKEN=""

# Better Auth
# Generate a strong secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
BETTER_AUTH_URL="http://localhost:3000"

# Public base URL used by the browser auth client
NEXT_PUBLIC_APP_URL="http://localhost:3000"
